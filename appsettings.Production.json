{
  "ConnectionStrings": {
    "MongoDB": "mongodb+srv://autonext_db_user:DubaiDutyFree%402026@autonext.qftgbeo.mongodb.net/Autonext_FileStorage_Production?retryWrites=true&w=majority&appName=Autonext"
  },
  "MongoDB": {
    "DatabaseName": "Autonext_FileStorage_Production",
    "FileMetadataCollection": "file_metadata",
    "ClientsCollection": "clients",
    "LogsCollection": "api_logs",
    "ConnectionPoolSize": 100,
    "MaxConnectionIdleTime": 120,
    "RetryWrites": true,
    "RetryReads": true,
    "WriteConcern": "majority",
    "ReadPreference": "primaryPreferred"
  },
  "FileStorage": {
    "UploadPath": "uploads",
    "MaxFileSizeBytes": 52428800,
    "MaxFileSizeMB": 50,
    "AllowedExtensions": [ ".jpg", ".jpeg", ".png", ".gif", ".webp", ".pdf", ".mp4", ".mov", ".zip", ".doc", ".docx", ".xls", ".xlsx" ],
    "BaseUrl": "https://autonext-blob.services.azurewebsites.betalen.in",
    "EnableCdn": true,
    "CdnUrl": "https://cdn.autonext.betalen.in",
    "EnableImageOptimization": true,
    "EnableThumbnailGeneration": true,
    "ThumbnailSizes": [ 150, 300, 600, 1200 ],
    "CompressionQuality": 80,
    "EnableSecurityScan": true,
    "VirusScanEnabled": true,
    "MaxUploadsPerMinute": 30,
    "MaxDailyUploadsPerClient": 1000
  },
  "Auth": {
    "EnableClientAuth": true,
    "HashSaltRounds": 12,
    "TokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7,
    "EnableIpWhitelisting": true,
    "EnableRateLimiting": true,
    "RateLimitPerMinute": 60,
    "MaxFailedAttempts": 5,
    "LockoutMinutes": 15
  },
  "Cache": {
    "EnableCaching": true,
    "CacheDurationMinutes": 30,
    "MaxCacheSizeMB": 512,
    "SlidingExpirationMinutes": 15,
    "RedisConnectionString": ""
  },
  "Security": {
    "CorsAllowedOrigins": [
      "https://admin.autonext.betalen.in",
      "https://api.autonext.betalen.in",
      "https://autonext.betalen.in"
    ],
    "EnableHttpsRedirection": true,
    "EnableRequestLogging": false,
    "EnableResponseCompression": true,
    "ForwardedHeaders": {
      "Enabled": true,
      "KnownNetworks": [],
      "KnownProxies": []
    }
  },
  "RateLimiting": {
    "Enabled": true,
    "GeneralPerSecond": 100,
    "UploadPerMinute": 30,
    "DownloadPerMinute": 200,
    "DeletePerMinute": 20
  },
  "Monitoring": {
    "EnableHealthChecks": true,
    "HealthCheckEndpoint": "/health",
    "EnableMetrics": true,
    "MetricsEndpoint": "/metrics",
    "EnableDetailedErrors": false,
    "EnableRequestTracing": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Authentication": "Information",
      "Microsoft.AspNetCore.Authorization": "Information",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.MongoDB" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "MongoDB.Driver": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}",
          "restrictedToMinimumLevel": "Information"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/api-log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 90,
          "fileSizeLimitBytes": 104857600,
          "rollOnFileSizeLimit": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}",
          "restrictedToMinimumLevel": "Information"
        }
      },
      {
        "Name": "MongoDB",
        "Args": {
          "databaseUrl": "mongodb+srv://autonext_db_user:DubaiDutyFree%402026@autonext.qftgbeo.mongodb.net/Autonext_FileStorage_Production?retryWrites=true&w=majority&appName=Autonext",
          "collectionName": "api_logs",
          "cappedMaxSizeMb": 500,
          "cappedMaxDocuments": 50000,
          "restrictedToMinimumLevel": "Warning",
          "batchPostingLimit": 50,
          "period": "00:00:02"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithEnvironmentUserName",
      "WithProcessId",
      "WithProcessName"
    ],
    "Properties": {
      "Application": "Autonext File Storage API",
      "Environment": "Production",
      "Version": "1.0.0"
    }
  },
  "Backup": {
    "Enabled": true,
    "BackupPath": "/backups/file-storage",
    "RetentionDays": 30,
    "BackupSchedule": "0 2 * * *",
    "AzureStorageConnectionString": "",
    "EnableCloudBackup": false
  },
  "Notification": {
    "EnableEmailAlerts": true,
    "AdminEmails": [
      "admin@autonext.betalen.in",
      "security@autonext.betalen.in"
    ],
    "EnableSlackNotifications": false,
    "SlackWebhookUrl": "",
    "AlertOnUploadFailure": true,
    "AlertOnSecurityIssue": true
  },
  "AllowedHosts": "*"
}