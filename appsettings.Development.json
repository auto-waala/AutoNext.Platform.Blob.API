{
  "ConnectionStrings": {
    "MongoDB": "mongodb+srv://autonext_db_user:DubaiDutyFree%402026@autonext.qftgbeo.mongodb.net/Autonext_FileStorage?retryWrites=true&w=majority&appName=Autonext"
  },
  "MongoDB": {
    "DatabaseName": "Autonext_FileStorage",
    "FileMetadataCollection": "file_metadata",
    "ClientsCollection": "clients",
    "LogsCollection": "api_logs"
  },
  "FileStorage": {
    "UploadPath": "uploads",
    "MaxFileSizeBytes": 52428800,
    "AllowedExtensions": [ ".jpg", ".jpeg", ".png", ".gif", ".pdf", ".mp4", ".zip", ".doc", ".docx" ],
    "BaseUrl": "https://autonext-blob.services.azurewebsites.betalen.in"
  },
  "Auth": {
    "EnableClientAuth": true,
    "HashSaltRounds": 12
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.MongoDB" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/api-log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "MongoDB",
        "Args": {
          "databaseUrl": "mongodb+srv://autonext_db_user:DubaiDutyFree%402026@autonext.qftgbeo.mongodb.net/Autonext_FileStorage?retryWrites=true&w=majority&appName=Autonext",
          "collectionName": "api_logs",
          "cappedMaxSizeMb": "100",
          "cappedMaxDocuments": "10000"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId", "WithEnvironmentUserName" ],
    "Properties": {
      "Application": "Autonext File Storage API"
    }
  },
  "AllowedHosts": "*"
}